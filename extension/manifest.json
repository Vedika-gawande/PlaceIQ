{
  "manifest_version": 3,
  "name": "PlaceIQ",
  "version": "1.0.0",
  "description": "Know exactly where you stand before placement season begins.",

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Open PlaceIQ"
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "permissions": ["tabs"],

  "host_permissions": [
    "https://place-iq.vercel.app/*",
    "https://placeiq-ogr7.onrender.com/*"
  ]
}